   491	function cmdTelemetryBaseline(cwd, opts, raw) {
   492	  const sessionMetaDir = getSessionMetaDir();
   493	  const facetsDir = getFacetsDir();
   494	  const { includeCaveated = false } = opts || {};
   495	
   496	  // Load full corpus with project filter
   497	  const corpus = loadSessionMetaCorpus(sessionMetaDir, { projectFilter: cwd, includeCaveated: true });
   498	  const facetsIndex = loadFacetsIndex(facetsDir);
   499	  const enriched = corpus.sessions.map(s => enrichSession(s, facetsIndex));
   500	
   501	  // Separate clean-only for default distributions
   502	  const cleanSessions = enriched.filter(s => s._tier === 'clean');
   503	  const distributionSource = includeCaveated ? enriched : cleanSessions;
   504	
   505	  // Primary behavioral distributions
   506	  const metrics = {
   507	    output_tokens: computeDistribution(distributionSource.map(s => s.output_tokens)),
   508	    tool_errors: computeDistribution(distributionSource.map(s => s.tool_errors)),
   509	    duration_minutes: computeDistribution(distributionSource.map(s => s.duration_minutes)),
   510	    user_interruptions: computeDistribution(distributionSource.map(s => s.user_interruptions))
   511	  };
   512	
   513	  // Computed metrics
   514	  const firstPromptBreakdown = computeBreakdown(enriched, s => s._first_prompt_category);
   515	  const focusLevelBreakdown = computeBreakdown(enriched, s => s._focus_level);
   516	  const entropyValues = enriched.map(s => s._hours_entropy);
   517	
   518	  const computedMetrics = {
   519	    first_prompt_category: firstPromptBreakdown,
   520	    focus_level: focusLevelBreakdown,
   521	    message_hours_entropy: computeDistribution(entropyValues)
   522	  };
   523	
   524	  // Facets metrics (on matched subset only)
   525	  const facetsMatched = enriched.filter(s => s._facet !== null);
   526	  const facetsFrictionValues = facetsMatched.map(s => {
   527	    if (!s._facet.friction_counts) return 0;
   528	    return Object.values(s._facet.friction_counts).reduce((sum, v) => sum + v, 0);
   529	  });
   530	
   531	  const facetsMetrics = {
   532	    _annotation: 'AI-generated estimates with unknown accuracy (TEL-05)',
   533	    _n: facetsMatched.length,
   534	    friction_counts: computeDistribution(facetsFrictionValues),
   535	    session_type: computeBreakdown(facetsMatched, s => s._facet.session_type),
   536	    outcome: computeBreakdown(facetsMatched, s => s._facet.outcome)
   537	  };
   538	
   539	  const baseline = {
   540	    generated_at: new Date().toISOString(),
   541	    schema_version: '1.0',
   542	    runtime: 'claude-code',
   543	    project: resolveWorktreeRoot(cwd),
   544	    corpus: {
   545	      total_files: corpus.stats.total_files,
   546	      clean_count: corpus.stats.clean,
   547	      caveated_count: corpus.stats.caveated,
   548	      excluded_count: corpus.stats.excluded,
   549	      malformed_count: corpus.stats.malformed
   550	    },
   551	    facets_coverage: {
   552	      total: enriched.length,
   553	      matched: facetsMatched.length,
   554	      coverage_pct: enriched.length > 0 ? parseFloat(((facetsMatched.length / enriched.length) * 100).toFixed(1)) : 0
   555	    },
   556	    metrics,
   557	    computed_metrics: computedMetrics,
   558	    facets_metrics: facetsMetrics,
   559	    interpretive_notes: buildInterpretiveNotes(),
   560	    token_validation: {
   561	      primary_source: 'output_tokens',
   562	      rationale: 'input_tokens is post-cache residual (1-3 tokens/call) -- not a workload proxy. output_tokens validated within 0-8% against JSONL in spk-004.',
   563	      input_tokens_warning: 'input_tokens values in session-meta are NOT session token workload. They reflect cache-miss residuals only.'
   564	    }
   565	  };
   566	
   567	  // Write baseline.json
   568	  const outputPath = path.join(resolveWorktreeRoot(cwd), '.planning', 'baseline.json');
   569	  atomicWriteJson(outputPath, baseline);
   570	
   571	  if (raw) {
   572	    output(baseline, raw);
   573	  } else {
   574	    const lines = [];
   575	    lines.push('=== Telemetry Baseline ===\n');
   576	    lines.push(`Generated: ${baseline.generated_at}`);
   577	    lines.push(`Project: ${baseline.project}`);
   578	    lines.push(`Corpus: ${baseline.corpus.total_files} files | ${baseline.corpus.clean_count} clean | ${baseline.corpus.caveated_count} caveated | ${baseline.corpus.excluded_count} excluded | ${baseline.corpus.malformed_count} malformed`);
   579	    lines.push(`Facets coverage: ${baseline.facets_coverage.matched}/${baseline.facets_coverage.total} (${baseline.facets_coverage.coverage_pct}%)\n`);
   580	    lines.push('Primary Distributions (clean only):');
   581	    lines.push(formatDistributionTable('output_tokens', metrics.output_tokens));
   582	    lines.push(formatDistributionTable('tool_errors', metrics.tool_errors));
   583	    lines.push(formatDistributionTable('duration_minutes', metrics.duration_minutes));
   584	    lines.push(formatDistributionTable('user_interruptions', metrics.user_interruptions));
   585	    lines.push(formatBreakdown('First Prompt Category', firstPromptBreakdown));
   586	    lines.push(formatBreakdown('Focus Level', focusLevelBreakdown));
   587	    lines.push(`\nBaseline written to: ${outputPath}`);
   588	    output({ baseline: lines.join('\n') }, false, lines.join('\n'));
   589	  }
   590	}
